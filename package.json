{
  "name": "pressly",
  "version": "1.0.0",
  "description": "Pressly — compress videos, images and extract audio. Built with Electron and ffmpeg.",
  "main": "main.js",
  "author": "designervkepke",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/designervkepke/pressly"
  },
  "keywords": [
    "electron",
    "ffmpeg",
    "video",
    "image",
    "compressor",
    "audio",
    "pressly"
  ],
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.designervkepke.pressly",
    "productName": "Pressly",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "publish": {
      "provider": "github",
      "owner": "designervkepke",
      "repo": "pressly"
    },
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "Pressly",
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "exiftool-vendored": "^35.20.0",
    "ffmpeg-static": "^5.3.0"
  }
}
